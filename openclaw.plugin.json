{
  "id": "memory-qdrant",
  "name": "三层记忆插件",
  "version": "2.0.0",
  "description": "OpenClaw 三层记忆架构插件 - 纯血极简版 (SQLite + Qdrant + AGE)",
  "main": "index.js",
  "type": "module",
  "kind": "lifecycle",
  "configSchema": {
    "type": "object",
    "properties": {
      "debug": { "type": "boolean", "default": false },
      "memoryServerUrl": { "type": "string", "default": "http://localhost:7777", "description": "memory-server 地址" },
      "qdrantUrl": { "type": "string", "default": "http://localhost:6333", "description": "Qdrant 管理地址 (6333)" },
      "qdrantGrpcPort": { "type": "number", "default": 6334, "description": "Qdrant gRPC 端口 (6334)" },
      "pgPort": { "type": "number", "default": 5432, "description": "PostgreSQL/AGE 端口 (5432)" },
      "collection": { "type": "string", "default": "openclaw_memories" },
      "authToken": { "type": "string", "default": "clawx-memory-token" },
      "recallEnabled": { "type": "boolean", "default": true },
      "addEnabled": { "type": "boolean", "default": true },
      "topK": { "type": "number", "default": 5 }
    }
  }
}
